<odoo>
    <data noupdate="0">

        <record id="rule_reception_animals" model="ir.rule">
            <field name="name">Recepció - accés animals</field>
            <field name="model_id" ref="model_animal"/>
            <field name="groups" eval="[(4, ref('vet.group_vet_reception'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_reception_visits" model="ir.rule">
            <field name="name">Recepció - accés visites</field>
            <field name="model_id" ref="model_animal_visit"/>
            <field name="groups" eval="[(4, ref('vet.group_vet_reception'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_doctor_animals_read" model="ir.rule">
            <field name="name">Veterinari - lectura animals</field>
            <field name="model_id" ref="model_animal"/>
            <field name="groups" eval="[(4, ref('vet.group_vet_doctor'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_doctor_visits_full" model="ir.rule">
            <field name="name">Veterinari - gestió visites</field>
            <field name="model_id" ref="model_animal_visit"/>
            <field name="groups" eval="[(4, ref('vet.group_vet_doctor'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_admin_all_animals" model="ir.rule">
            <field name="name">Administració - accés complet animals</field>
            <field name="model_id" ref="model_animal"/>
            <field name="groups" eval="[(4, ref('vet.group_vet_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <record id="rule_admin_all_visits" model="ir.rule">
            <field name="name">Administració - accés complet visites</field>
            <field name="model_id" ref="model_animal_visit"/>
            <field name="groups" eval="[(4, ref('vet.group_vet_admin'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

    </data>
</odoo>
